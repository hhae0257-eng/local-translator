{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Local Translator",
  "version": "0.2.1",
  "identifier": "com.localhost.localtranslator",
  "build": {
    "beforeDevCommand": "npx vite",
    "beforeBuildCommand": "npx vite build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Local Translator",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ5QURENkZGQzQ1NjQyMzQKUldRMFFsYkUvOWF0U1F3N2JOUFUvc083ZEhmNmpUQkFnQzE3b3ZjMVZRcUYyTUhwUFVDdHNZM3QK",
      "endpoints": [
        "https://github.com/hhae0257-eng/local-translator/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
